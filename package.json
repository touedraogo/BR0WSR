{
  "name": "browser-electron-nordvpn",
  "version": "1.0.0",
  "description": "Secure Browser with NordVPN integration",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9"
  },
  "dependencies": {
    "@cliqz/adblocker-electron": "^1.34.0",
    "node-pty": "^1.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "build": {
    "appId": "com.nordvpn.browser",
    "productName": "NordVPN Browser",
    "mac": {
      "category": "public.app-category.utilities",
      "target": ["dmg"]
    },
    "dmg": {
      "title": "NordVPN Browser",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
